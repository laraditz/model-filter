{
  "name": "laraditz/model-filter",
  "description": "A simple eloquent model filter.",
  "type": "laravel-package",
  "keywords": [
    "laravel",
    "eloquent",
    "model",
    "filter"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Raditz Farhan",
      "email": "raditzfarhan@gmail.com"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "^8.1",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
    "illuminate/database": "^9.0|^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "pestphp/pest": "^3.0",
    "orchestra/testbench": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Laraditz\\ModelFilter\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "App\\Filters\\": "tests/Fixtures/Filters/"
    }
  },
  "scripts": {
    "test": "./vendor/bin/pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Laraditz\\ModelFilter\\ModelFilterServiceProvider"
      ]
    }
  }
}
